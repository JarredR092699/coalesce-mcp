# Coalesce API token — get this from Coalesce Settings → API Tokens
COALESCE_API_TOKEN=your-token-here

# Optional: override the base URL for on-prem deployments
# COALESCE_BASE_URL=https://app.coalescesoftware.io/api/

# Optional: set to true to disable write tools (create/update nodes)
# COALESCE_READONLY_MODE=false
